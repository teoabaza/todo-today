# Server
PORT=4000
NODE_ENV=development

# Database (Postgres connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/todotoday-db?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# CORS - comma separated origins, use * for any
CORS_ORIGIN="*"
